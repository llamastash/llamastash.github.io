---
import InstallTabs from "./InstallTabs.astro";
---

<section class="relative mx-auto max-w-6xl px-6 pt-20 pb-24 sm:pt-28 sm:pb-32">
  <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-center">
    <div class="lg:col-span-3">
      <p class="font-mono text-sm uppercase tracking-widest text-catppuccin-mauve mb-4">
        Local LLMs · TUI · Rust
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05] text-catppuccin-text">
        Launch local models <span class="text-catppuccin-mauve">without leaving</span> the terminal.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-catppuccin-subtext1 max-w-2xl">
        llamastash is a fast, keyboard-driven TUI for browsing your GGUF library and running llama.cpp models. No daemon, no Electron, no cloud — just one binary that knows your hardware.
      </p>

      <div class="mt-10">
        <InstallTabs />
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-catppuccin-overlay1 font-mono">
        <span class="flex items-center gap-1.5"><span class="inline-block h-1.5 w-1.5 rounded-full bg-catppuccin-green"></span> localhost-only</span>
        <span class="flex items-center gap-1.5"><span class="inline-block h-1.5 w-1.5 rounded-full bg-catppuccin-green"></span> MIT licensed</span>
        <span class="flex items-center gap-1.5"><span class="inline-block h-1.5 w-1.5 rounded-full bg-catppuccin-green"></span> no telemetry</span>
      </div>
    </div>

    <div class="lg:col-span-2 w-full">
      <div class="rounded-lg overflow-hidden border border-catppuccin-surface0 bg-catppuccin-mantle shadow-xl shadow-black/40">
        <div class="flex items-center gap-1.5 px-3 py-2 border-b border-catppuccin-surface0 bg-catppuccin-crust">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-catppuccin-red"></span>
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-catppuccin-yellow"></span>
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-catppuccin-green"></span>
          <span class="ml-2 text-xs font-mono text-catppuccin-overlay1">llamastash · ~/models</span>
        </div>
        <div id="demo-cast-container" class="demo-asciinema bg-catppuccin-mantle aspect-[16/10]">
          <noscript>
            <img
              src="/screenshots/hero-static.png"
              alt="llamastash TUI showing model list and resource panels"
              class="w-full h-auto"
              width="800"
              height="500"
            />
          </noscript>
        </div>
        <img
          src="/screenshots/hero-static.png"
          alt="llamastash TUI showing model list and resource panels"
          class="demo-static w-full h-auto"
          width="800"
          height="500"
          loading="lazy"
        />
      </div>
      <p class="mt-3 text-center text-xs text-catppuccin-overlay1">
        Recorded session · auto-loops · reduced motion swaps to static image
      </p>
    </div>
  </div>
</section>

<script>
  // Lazy-load asciinema-player only when the cast container is in view and
  // the user hasn't requested reduced motion. The component is the largest
  // single JS payload on the page; deferring keeps first paint snappy.
  const container = document.getElementById("demo-cast-container");
  if (container && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const load = async () => {
      const player = await import("asciinema-player");
      await import("asciinema-player/dist/bundle/asciinema-player.css");
      player.create("/demo.cast", container, {
        loop: true,
        autoPlay: true,
        speed: 1.5,
        idleTimeLimit: 1.5,
        theme: "catppuccin-macchiato",
        poster: "npt:0:00",
        controls: false,
      });
    };

    const io = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.disconnect();
          load().catch(() => {
            // Fall back silently to the static image (already in the DOM).
          });
        }
      });
    });
    io.observe(container);
  }
</script>
