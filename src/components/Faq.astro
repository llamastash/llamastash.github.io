---
import { faq } from "../data/faq.ts";
---

<section id="faq" class="border-t border-catppuccin-surface0">
  <div class="mx-auto max-w-3xl px-6 py-24">
    <div class="mb-12 text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-catppuccin-mauve mb-3">FAQ</p>
      <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-catppuccin-text">
        Common questions
      </h2>
    </div>

    <ul class="space-y-3">
      {faq.map((entry) => (
        <li>
          <details class="group rounded-lg border border-catppuccin-surface0 bg-catppuccin-mantle/60 hover:border-catppuccin-surface1 transition">
            <summary class="flex items-center justify-between gap-4 px-5 py-4 text-catppuccin-text font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-catppuccin-mauve rounded-lg">
              <span>{entry.q}</span>
              <svg
                class="faq-chevron h-4 w-4 shrink-0 text-catppuccin-overlay1"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                  clip-rule="evenodd"
                />
              </svg>
            </summary>
            <div class="px-5 pb-5 -mt-1 text-sm leading-relaxed text-catppuccin-subtext1">
              {entry.a}
            </div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>
